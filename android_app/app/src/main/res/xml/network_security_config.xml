<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Zezwalaj na HTTP tylko dla lokalnych adresów IP i sieci prywatnych (development) -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Lokalne hosty -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        
        <!-- Prywatne zakresy IP (RFC 1918) - typowe adresy lokalne -->
        <!-- Dla Androida musimy użyć wzorców z wildcard aby obsłużyć całe zakresy -->
        <!-- 10.0.0.0/8 -->
        <domain includeSubdomains="true">10.*</domain>
        <!-- 172.16.0.0/12 -->
        <domain includeSubdomains="true">172.16.*</domain>
        <domain includeSubdomains="true">172.17.*</domain>
        <domain includeSubdomains="true">172.18.*</domain>
        <domain includeSubdomains="true">172.19.*</domain>
        <domain includeSubdomains="true">172.20.*</domain>
        <domain includeSubdomains="true">172.21.*</domain>
        <domain includeSubdomains="true">172.22.*</domain>
        <domain includeSubdomains="true">172.23.*</domain>
        <domain includeSubdomains="true">172.24.*</domain>
        <domain includeSubdomains="true">172.25.*</domain>
        <domain includeSubdomains="true">172.26.*</domain>
        <domain includeSubdomains="true">172.27.*</domain>
        <domain includeSubdomains="true">172.28.*</domain>
        <domain includeSubdomains="true">172.29.*</domain>
        <domain includeSubdomains="true">172.30.*</domain>
        <domain includeSubdomains="true">172.31.*</domain>
        <!-- 192.168.0.0/16 -->
        <domain includeSubdomains="true">192.168.*</domain>
        
        <!-- Uwaga: Android nie obsługuje pełnych zakresów CIDR w domain-config.
             Powyższe domeny używają wildcard (*) aby obsłużyć całe zakresy prywatnych IP.
             
             Alternatywnie, w buildzie debug można użyć android:usesCleartextTraffic="true"
             w AndroidManifest.xml zamiast tej konfiguracji.
        -->
        
        <!-- Przykładowe adresy z każdego zakresu - należy dodać konkretne IP używane w aplikacji -->
        <domain includeSubdomains="true">10.0.0.1</domain>
        <domain includeSubdomains="true">10.0.0.254</domain>
        <domain includeSubdomains="true">172.16.0.1</domain>
        <domain includeSubdomains="true">172.31.255.254</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.1.100</domain>
        <domain includeSubdomains="true">192.168.1.254</domain>
        
        <!-- Dodaj tutaj konkretne adresy IP swoich urządzeń Raspberry Pi -->
        <!-- <domain includeSubdomains="true">192.168.1.XXX</domain> -->
        
    </domain-config>
    
    <!-- Domyślnie blokuj cleartext traffic dla wszystkich innych połączeń -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- 
    UWAGA DLA DEVELOPERÓW:
    
    Jeśli potrzebujesz obsługi DOWOLNYCH adresów IP w sieci lokalnej (nie tylko tych wymienionych powyżej),
    masz dwie opcje:
    
    1. W pliku AndroidManifest.xml, w sekcji <application> dodaj:
       android:networkSecurityConfig="@xml/network_security_config"
       
       I w build.gradle (dla wersji debug):
       android:usesCleartextTraffic="true"
       
    2. Lub zmodyfikuj ten plik aby zawierał WSZYSTKIE konkretne adresy IP których używasz.
    
    Dla produkcji ZALECANE jest użycie HTTPS zamiast HTTP.
    -->
</network-security-config>

```
# Android build artifacts
*.apk
*.aar
*.dex
*.so

# Android build directories
build/
.gradle/
*/build/
*/.gradle/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA artifacts
*.iml
*.iws
.idea/

# Temporary files
*.tmp
*.temp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
coverage/
*.gcov
*.lcov
*.profdata

# Python cache (if any Python scripts exist in the project)
__pycache__/
*.pyc
*.pyo
```